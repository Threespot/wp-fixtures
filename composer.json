{
    "name": "threespot/wp-fixtures",
    "description": "Example content loader for new Threespot WordPress sites. Dev-dependency only.",
    "type": "library",
    "license": "MIT",
    "keywords": ["wordpress", "wp-cli", "fixtures", "threespot"],
    "homepage": "https://github.com/threespot/wp-fixtures",
    "authors": [
        {
            "name": "Threespot",
            "homepage": "https://threespot.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/yaml": "^6.4 || ^7.0"
    },
    "require-dev": {
        "wp-cli/wp-cli": "^2.10"
    },
    "autoload": {
        "psr-4": {
            "Threespot\\WpFixtures\\": "src/"
        },
        "files": [
            "bootstrap.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
